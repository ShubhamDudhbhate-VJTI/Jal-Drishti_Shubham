# ===========================================
# Jal-Drishti — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# ── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Frontend (Vite) — uses anon key (safe for browser) ──────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Backend API URL (for frontend to call) ───────────────────
# Local dev: http://localhost:8000
# Production: https://your-backend.railway.app (or Render URL)
VITE_API_BASE_URL=http://localhost:8000

# ── AI Chatbot (Groq — free cloud LLM) ──────────────────────
# Sign up at https://console.groq.com → create API key
GROQ_API_KEY=your-groq-api-key

# ── CORS (Backend — optional, defaults to *) ─────────────────
# Comma-separated origins, e.g.: https://jal-drishti.vercel.app,http://localhost:8080
# ALLOWED_ORIGINS=*
